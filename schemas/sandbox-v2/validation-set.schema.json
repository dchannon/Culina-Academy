{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dchannon/Culina-Academy/schemas/sandbox-v2/validation-set.schema.json",
  "title": "Culina V2 Validation Set Example",
  "type": "object",
  "required": ["schemaVersion", "validationSet"],
  "properties": {
    "schemaVersion": { "const": "culina.framework.config.v2.example" },
    "validationSet": {
      "type": "object",
      "required": ["validationSetId", "appliesTo", "checks"],
      "properties": {
        "validationSetId": { "type": "string", "minLength": 1 },
        "appliesTo": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["checkId", "type", "severity"],
            "properties": {
              "checkId": { "type": "string", "minLength": 1 },
              "type": { "type": "string", "minLength": 1 },
              "fields": { "type": "array", "items": { "type": "string" } },
              "description": { "type": "string" },
              "minimum": { "type": "integer", "minimum": 0 },
              "severity": { "enum": ["warn", "fail"] }
            }
          }
        }
      }
    }
  }
}
