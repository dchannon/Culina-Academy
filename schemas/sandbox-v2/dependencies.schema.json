{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dchannon/Culina-Academy/schemas/sandbox-v2/dependencies.schema.json",
  "title": "Culina V2 Dependency Example",
  "type": "object",
  "required": ["schemaVersion", "dependencies"],
  "properties": {
    "schemaVersion": { "const": "culina.framework.config.v2.example" },
    "dependencies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["dependencyId", "upstreamJobId", "downstreamJobId", "condition", "releasePoint"],
        "properties": {
          "dependencyId": { "type": "string", "minLength": 1 },
          "upstreamJobId": { "type": "string", "minLength": 1 },
          "downstreamJobId": { "type": "string", "minLength": 1 },
          "condition": { "type": "string", "minLength": 1 },
          "releasePoint": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
